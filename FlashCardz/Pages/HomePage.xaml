<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FlashCardz.Controls"
             x:Class="FlashCardz.Pages.HomePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFFEF5">

    <Grid RowDefinitions="Auto, *, Auto">

      

        <!-- Search bar -->
        <controls:WobblyBorder Grid.Row="0"
                               Margin="24,20,24,10"
                               HeightRequest="50"
                               WobblyFillColor="#FFFFFF">
            <SearchBar x:Name="SearchBar"
                       Placeholder="Search..."
                       BackgroundColor="Transparent"
                       TextChanged="OnSearchChanged"/>
        </controls:WobblyBorder>

        <!-- Deck list -->
        <ScrollView Grid.Row="1" Margin="24,0">
            <VerticalStackLayout x:Name="DeckList"
                                 Spacing="16"
                                 Padding="0,8,0,8"/>
        </ScrollView>

        <!-- Popup overlay -->
        <Grid x:Name="PopupOverlay"
              Grid.RowSpan="3"
              BackgroundColor="#80000000"
              IsVisible="False">
            <controls:WobblyBorder WidthRequest="300"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   WobblyFillColor="#FFFEF5">
                <VerticalStackLayout Spacing="16"
                                     Padding="8">

                    <Label x:Name="PopupTitle"
                           Style="{StaticResource SubtitleLabel}"
                           HorizontalOptions="Center"/>

                    <Label x:Name="PopupContent"
                           HorizontalTextAlignment="Center"
                           MaxLines="3"
                           LineBreakMode="TailTruncation"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <controls:WobblyButton Grid.Column="0"
                                               Text="← Back"
                                               HeightRequest="40"
                                               Clicked="OnPopupBackClicked"/>
                        <controls:WobblyButton Grid.Column="1"
                                               Text="Continue →"
                                               HeightRequest="40"
                                               Clicked="OnPopupContinueClicked"/>
                    </Grid>

                </VerticalStackLayout>
            </controls:WobblyBorder>
        </Grid>

        <!-- Bottom nav -->
        <controls:WobblyBorder Grid.Row="2"
                               HeightRequest="64"
                               WobblyFillColor="#FFFEF5">
            <Grid ColumnDefinitions="*, *, *">
                <Button Grid.Column="0"
                        Text="🏚️"
                        FontSize="24"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource SketchInk}"
                        Clicked="OnHomeClicked"/>
                <Button Grid.Column="1"
                        Text="+"
                        FontSize="28"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource SketchInk}"
                        Clicked="OnAddClicked"/>
                <Button Grid.Column="2"
                        Text="👤"
                        FontSize="24"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource SketchInk}"
                        Clicked="OnProfileClicked"/>
            </Grid>
        </controls:WobblyBorder>

    </Grid>

</ContentPage>
