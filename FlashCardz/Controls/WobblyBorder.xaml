<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashCardz.Controls.WobblyBorder"
             VerticalOptions="FillAndExpand"
             HorizontalOptions="Fill">

    <Grid VerticalOptions="FillAndExpand">
        <!-- Border drawn behind everything -->
        <GraphicsView x:Name="BorderCanvas"
                      InputTransparent="True"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"/>

        <!-- Content on top, with padding so it sits inside the wobbly border -->
        <ContentPresenter x:Name="InnerContent"
                          InputTransparent="False"
                          VerticalOptions="Fill"
                          HorizontalOptions="Fill"
                          Margin="10,6"/>
    </Grid>

</ContentView>