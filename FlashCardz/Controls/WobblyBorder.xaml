        <!-- Wobbly border background -->
        <GraphicsView x:Name="BorderCanvas"/>

        <!-- Actual content sits on top -->
        <ContentPresenter x:Name="InnerContent"
                          Margin="14,10"/>
    </Grid>

</ContentView>